{{- $pages := .Pages.ByDate.Reverse -}}
{{- $rssLimit := .Site.Config.Services.RSS.Limit -}}
{{- if and (gt $rssLimit 0) (le $rssLimit (len $pages)) -}}
  {{- $pages = $pages | first $rssLimit -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Blog | Nexus AI — Inteligencia Artificial para Empresas</title>
    <link>{{ .Permalink }}</link>
    <description>Artículos, guías y casos prácticos sobre inteligencia artificial empresarial, automatización, chatbots, agentes IA, MCP y transformación digital.</description>
    <language>{{ .Site.Language.LanguageCode | default "es-ES" }}</language>
    <managingEditor>{{ .Site.Params.email }} ({{ .Site.Params.author }})</managingEditor>
    <webMaster>{{ .Site.Params.email }} ({{ .Site.Params.author }})</webMaster>
    <copyright>Copyright {{ now.Format "2006" }} {{ .Site.Params.author }}. Todos los derechos reservados.</copyright>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <image>
      <url>{{ .Site.BaseURL }}assets/icons/favicon.svg</url>
      <title>Blog | Nexus AI</title>
      <link>{{ .Permalink }}</link>
    </image>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <guid>{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <author>{{ .Site.Params.email }} ({{ .Params.author | default .Site.Params.author }})</author>
      <dc:creator>{{ .Params.author | default .Site.Params.author }}</dc:creator>
      {{- with .Params.tags }}
        {{- range . }}
      <category>{{ . }}</category>
        {{- end }}
      {{- end }}
      <description>{{ .Summary | plainify | html }}</description>
    </item>
    {{- end }}
  </channel>
</rss>